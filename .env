# Environment variables for the Docker task application
APP_PORT=8080
IMAGE_TAG=latest
IMAGE_NAME=docker-task-app
CONTAINER_NAME=docker-task-app-ctr
REVERSE_PROXY_CONTAINER_NAME=nginx-reverse-proxy-ctr
APP_SOURCE_PATH=./app
APP_TARGET_PATH=/usr/share/nginx/html
APP_DATA_VOLUME=task-app-data
APP_DATA_TARGET_PATH=/var/lib/task-app-data
NETWORK_NAME=task-app-network